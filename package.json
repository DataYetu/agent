{
  "name": "datayetu-agent",
  "version": "1.0.0",
  "description": "CROO-native oracle agent: human-validated, confidence-scored answers settled via CAP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "tsx --test tests/*.test.ts",
    "a2a": "tsx scripts/a2a-requester.ts"
  },
  "keywords": [
    "croo",
    "cap",
    "oracle",
    "agent",
    "a2a",
    "h2a",
    "telegram"
  ],
  "license": "MIT",
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "node-telegram-bot-api": "^0.66.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
