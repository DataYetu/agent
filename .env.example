# ── CROO Agent Protocol (CAP) ─────────────────────────────────────────────
# Values from the CROO Dashboard (https://croo.network) after registering the
# agent + service and issuing an SDK-Key. Fund the agent AA wallet with USDC on
# Base before accepting paid orders.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx
CROO_SERVICE_ID=svc_xxxxxxxxxxxx
# Optional: custom Base JSON-RPC endpoint (defaults to https://mainnet.base.org)
BASE_RPC_URL=https://mainnet.base.org
# Required only if the CROO service has "Require Fund Transfer" enabled.
# Prefer turning that OFF for an oracle; otherwise set the agent AA wallet address.
# PROVIDER_FUND_ADDRESS=0x...

# ── Telegram Validator Network ────────────────────────────────────────────
# Bot token from @BotFather; group id of the private validator group.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_GROUP_ID=-1001234567890

# ── Runtime ───────────────────────────────────────────────────────────────
# Milliseconds to wait for a human validator before LLM fallback / fail (1.5 min).
VALIDATOR_TIMEOUT_MS=90000
# Service price ceiling (in the service currency, e.g. USDC). Negotiations
# requesting more than this are rejected.
SERVICE_PRICE=0.05
SERVICE_CURRENCY=USDC
# HTTP port for the health + local dev endpoints.
PORT=3000
# Set to "true" to enable the local POST /agent/query dev endpoint (bypasses CAP).
ENABLE_DEV_ENDPOINT=false

# ── LLM fallback (Groq free tier recommended) ─────────────────────────────
# If no human replies before VALIDATOR_TIMEOUT_MS, answer via Groq and deliver.
# Setting GROQ_API_KEY auto-enables fallback (unless LLM_FALLBACK_ENABLED=false).
GROQ_API_KEY=
LLM_FALLBACK_ENABLED=true
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_CONFIDENCE=0.65
# Or use OpenAI / any OpenAI-compatible endpoint via LLM_API_KEY instead.
